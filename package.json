{
	"name": "kongcheck",
	"version": "1.0.0",
	"private": true,
	"description": "CLI tool for detecting Kong Konnect route collisions and shadowing",
	"author": {
		"name": "GP",
		"email": "prasannah.ganesh@bcg.com"
	},
	"bin": {
		"kongcheck": "./src/cli.ts"
	},
	"scripts": {
		"start": "bun run src/cli.ts",
		"test": "bun test src/",
		"test:coverage": "bun test src/ --coverage",
		"typecheck": "tsc --noEmit",
		"build": "bun build --compile --target bun --outfile dist/kongcheck src/cli.ts",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.29.0",
		"cac": "7.0.0",
		"nspin-bun": "1.2.0",
		"tiny-relative-date": "2.0.2"
	},
	"devDependencies": {
		"@types/bun": "1.3.13",
		"oxfmt": "0.48.0",
		"oxlint": "1.63.0",
		"oxlint-tsgolint": "0.22.1",
		"typescript": "6.0.3"
	},
	"devEngines": {
		"runtime": {
			"name": "bun",
			"onFail": "error"
		}
	},
	"engines": {
		"bun": "*"
	}
}
