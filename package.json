{
	"name": "kongcheck",
	"version": "1.2.0",
	"description": "CLI tool for detecting Kong Konnect route collisions and shadowing",
	"keywords": [
		"analyze",
		"audit",
		"cli",
		"kong",
		"konnect",
		"router"
	],
	"homepage": "https://github.com/paambaati/kongcheck#readme",
	"bugs": "https://github.com/paambaati/kongcheck/issues",
	"license": "MIT",
	"author": {
		"name": "GP",
		"email": "me@httgp.com",
		"url": "https://httgp.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/paambaati/kongcheck.git"
	},
	"scripts": {
		"start": "bun run src/cli.ts",
		"test": "bun test src/",
		"test:coverage": "bun test src/ --coverage",
		"typecheck": "tsc --noEmit",
		"build": "bun build --compile --target bun --outfile dist/kongcheck src/cli.ts",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.29.0",
		"cac": "7.0.0",
		"nspin-bun": "1.2.1",
		"tiny-relative-date": "2.0.2"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.24.0",
		"typescript": "7.0.2"
	},
	"devEngines": {
		"runtime": {
			"name": "bun",
			"onFail": "error"
		}
	}
}
